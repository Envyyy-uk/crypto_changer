# --- Runtime ---
NODE_ENV=development
PORT=3000

# --- PostgreSQL ---
POSTGRES_USER=exchange
POSTGRES_PASSWORD=exchange
POSTGRES_DB=crypto_exchange
DATABASE_URL=postgresql://exchange:exchange@localhost:5432/crypto_exchange?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
LOGIN_LOCKOUT_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_DURATION_MINUTES=15

# --- Sandbox funding ---
TEST_LIQUIDITY_USDT_AMOUNT=100000

# --- Market-maker bot (simulated liquidity) ---
MARKET_MAKER_ENABLED=true
MARKET_MAKER_INTERVAL_MS=5000
